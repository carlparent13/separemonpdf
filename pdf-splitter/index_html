<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PDF Splitter</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    color: #e2e8f0;
  }
  .card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 36px;
    width: 100%;
    max-width: 560px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.4);
  }
  .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
  .logo-icon {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, #e94560, #c62a47);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; box-shadow: 0 4px 15px rgba(233,69,96,0.4);
  }
  .logo h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }
  .logo span { font-size: 13px; color: #94a3b8; font-weight: 400; display: block; }

  .drop-zone {
    border: 2px dashed rgba(255,255,255,0.2);
    border-radius: 14px; padding: 40px 24px;
    text-align: center; cursor: pointer;
    transition: all 0.3s; background: rgba(255,255,255,0.03); position: relative;
  }
  .drop-zone:hover, .drop-zone.dragover { border-color: #e94560; background: rgba(233,69,96,0.06); }
  .drop-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .drop-icon { font-size: 40px; margin-bottom: 12px; }
  .drop-zone p { color: #94a3b8; font-size: 14px; }
  .drop-zone strong { color: #e2e8f0; }

  .info-badge {
    background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.2));
    border: 1px solid rgba(99,102,241,0.3);
    border-radius: 12px; padding: 14px 18px;
    display: flex; align-items: center; gap: 12px; margin-top: 16px;
  }
  .info-badge .badge-text { font-size: 13px; }
  .info-badge strong { color: #a5b4fc; font-size: 15px; }

  .section { margin-top: 24px; }
  label { font-size: 13px; color: #94a3b8; font-weight: 500; display: block; margin-bottom: 8px; }
  label span.req { color: #e94560; margin-left: 3px; }

  input[type="text"], input[type="number"] {
    width: 100%;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px; padding: 11px 14px;
    color: #e2e8f0; font-size: 14px; outline: none; transition: border-color 0.2s;
  }
  input:focus { border-color: #e94560; }
  input::placeholder { color: #475569; }

  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

  .preview-pill {
    display: none;
    background: rgba(16,185,129,0.15);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: 10px; padding: 10px 14px;
    font-size: 13px; color: #6ee7b7; margin-top: 10px;
  }
  .preview-pill.visible { display: block; }

  .pw-section {
    display: none; margin-top: 16px; padding: 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;
  }
  .pw-section.visible { display: block; }
  .pw-match { font-size: 12px; margin-top: 6px; height: 16px; }
  .pw-match.ok { color: #6ee7b7; }
  .pw-match.err { color: #f87171; }

  .radio-group { display: flex; gap: 12px; margin-top: 4px; }
  .radio-btn {
    flex: 1; padding: 11px; border-radius: 10px; cursor: pointer;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: #94a3b8; transition: all 0.2s; user-select: none;
  }
  .radio-btn.selected { border-color: #e94560; background: rgba(233,69,96,0.12); color: #e2e8f0; }
  .radio-dot {
    width: 16px; height: 16px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.3);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .radio-btn.selected .radio-dot { border-color: #e94560; }
  .radio-dot::after { content:''; width:8px; height:8px; border-radius:50%; background:#e94560; display:none; }
  .radio-btn.selected .radio-dot::after { display: block; }

  .divider { height: 1px; background: rgba(255,255,255,0.08); margin: 24px 0; }

  .btn-process {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #e94560, #c62a47);
    border: none; border-radius: 12px;
    color: #fff; font-size: 15px; font-weight: 600;
    cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    box-shadow: 0 4px 15px rgba(233,69,96,0.3);
  }
  .btn-process:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(233,69,96,0.45); }
  .btn-process:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .progress-wrap { display: none; margin-top: 20px; }
  .progress-wrap.visible { display: block; }
  .progress-bar-track { background: rgba(255,255,255,0.08); border-radius: 999px; height: 8px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #e94560, #f472b6); width: 0%; transition: width 0.4s; }
  .progress-label { font-size: 12px; color: #64748b; margin-top: 6px; text-align: center; }

  .download-wrap { display: none; margin-top: 20px; }
  .download-wrap.visible { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .btn-download {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #10b981, #059669);
    border: none; border-radius: 12px;
    color: #fff; font-size: 15px; font-weight: 600;
    cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    box-shadow: 0 4px 15px rgba(16,185,129,0.3); text-decoration: none;
  }
  .btn-download:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,185,129,0.45); }
  .success-msg { font-size: 13px; color: #6ee7b7; text-align: center; }

  .error-msg { color: #f87171; font-size: 13px; margin-top: 8px; display: none; }
  .error-msg.visible { display: block; }

  .reset-link {
    background: none; border: none; color: #64748b; font-size: 12px;
    cursor: pointer; text-decoration: underline; margin-top: 4px;
  }
  .reset-link:hover { color: #94a3b8; }

  .footer { margin-top: 20px; font-size: 12px; color: rgba(255,255,255,0.25); text-align: center; letter-spacing: 0.3px; }
</style>
</head>
<body>
<div class="card">
  <div class="logo">
    <div class="logo-icon">✂️</div>
    <div>
      <h1>PDF Splitter</h1>
      <span>Séparateur de documents PDF</span>
    </div>
  </div>

  <!-- Upload -->
  <div class="drop-zone" id="dropZone">
    <input type="file" id="fileInput" accept=".pdf">
    <div class="drop-icon">📄</div>
    <p><strong>Glisse un PDF ici</strong> ou clique pour choisir</p>
    <p style="margin-top:6px;font-size:12px;">Fichiers PDF uniquement</p>
  </div>

  <div class="info-badge" id="infoBadge" style="display:none;">
    <div style="font-size:24px;">📊</div>
    <div class="badge-text">
      <strong id="pageCountText"></strong>
      <div id="fileNameText" style="color:#94a3b8;margin-top:2px;"></div>
    </div>
  </div>

  <!-- Paramètres -->
  <div class="section" id="paramsSection" style="display:none;">
    <div class="divider"></div>
    <div class="row">
      <div>
        <label>Pages par document <span class="req">*</span></label>
        <input type="number" id="pagesPerDoc" min="1" placeholder="ex. 2">
        <div class="preview-pill" id="previewPill"></div>
      </div>
      <div>
        <label>Titre des documents <span class="req">*</span></label>
        <input type="text" id="docTitle" placeholder="ex. Quiz mathématiques">
      </div>
    </div>

    <!-- Mot de passe -->
    <div class="section">
      <label>Protection par mot de passe <span class="req">*</span></label>
      <div class="radio-group">
        <label class="radio-btn" id="radioNo" onclick="selectPw(false)">
          <div class="radio-dot"></div>
          🔓 Sans protection
        </label>
        <label class="radio-btn" id="radioYes" onclick="selectPw(true)">
          <div class="radio-dot"></div>
          🔒 Avec mot de passe
        </label>
      </div>
    </div>

    <div class="pw-section" id="pwSection">
      <div>
        <label>Mot de passe</label>
        <input type="text" id="pw1" placeholder="Entrer le mot de passe">
      </div>
      <div style="margin-top:12px;">
        <label>Confirmer le mot de passe</label>
        <input type="text" id="pw2" placeholder="Répéter le mot de passe" oninput="checkPw()">
        <div class="pw-match" id="pwMatch"></div>
      </div>
    </div>

    <div class="error-msg" id="errorMsg"></div>

    <div style="margin-top:24px;">
      <button class="btn-process" id="btnProcess" onclick="process()">
        ✂️ Découper et créer le ZIP
      </button>
    </div>

    <div class="progress-wrap" id="progressWrap">
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="progressFill"></div>
      </div>
      <div class="progress-label" id="progressLabel">Envoi au serveur...</div>
    </div>

    <div class="download-wrap" id="downloadWrap">
      <div class="success-msg" id="successMsg"></div>
      <a class="btn-download" id="downloadLink" href="#">
        📦 Télécharger le fichier ZIP
      </a>
      <button class="reset-link" onclick="reset()">Traiter un autre fichier</button>
    </div>
  </div>
</div>

<div class="footer">Carl Parent — 2026</div>

<script>
let pdfBytes = null, pageCount = 0, originalFileName = '', pwSelected = null;

// Drag & Drop
const dz = document.getElementById('dropZone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('dragover'); handleFile(e.dataTransfer.files[0]); });
document.getElementById('fileInput').addEventListener('change', e => handleFile(e.target.files[0]));

async function handleFile(file) {
  if (!file || !file.name.toLowerCase().endsWith('.pdf')) { showError('Veuillez choisir un fichier PDF valide.'); return; }
  originalFileName = file.name.replace(/\.pdf$/i, '');
  const ab = await file.arrayBuffer();
  pdfBytes = new Uint8Array(ab);
  try {
    const doc = await PDFLib.PDFDocument.load(pdfBytes, { ignoreEncryption: true });
    pageCount = doc.getPageCount();
  } catch(e) { showError('Impossible de lire ce PDF.'); return; }
  document.getElementById('pageCountText').textContent = `${pageCount} page${pageCount > 1 ? 's' : ''} détectée${pageCount > 1 ? 's' : ''}`;
  document.getElementById('fileNameText').textContent = file.name;
  document.getElementById('infoBadge').style.display = 'flex';
  document.getElementById('paramsSection').style.display = 'block';
  document.getElementById('pagesPerDoc').max = pageCount;
}

document.getElementById('pagesPerDoc').addEventListener('input', updatePreview);
function updatePreview() {
  const n = parseInt(document.getElementById('pagesPerDoc').value);
  const pill = document.getElementById('previewPill');
  if (!n || n < 1 || !pageCount) { pill.classList.remove('visible'); return; }
  const count = Math.ceil(pageCount / n);
  pill.textContent = `→ ${count} document${count > 1 ? 's' : ''} seront créés`;
  pill.classList.add('visible');
}

function selectPw(val) {
  pwSelected = val;
  document.getElementById('radioYes').classList.toggle('selected', val === true);
  document.getElementById('radioNo').classList.toggle('selected', val === false);
  document.getElementById('pwSection').classList.toggle('visible', val === true);
  if (!val) { document.getElementById('pw1').value = ''; document.getElementById('pw2').value = ''; document.getElementById('pwMatch').textContent = ''; }
}

function checkPw() {
  const p1 = document.getElementById('pw1').value, p2 = document.getElementById('pw2').value;
  const el = document.getElementById('pwMatch');
  if (!p2) { el.textContent = ''; return; }
  if (p1 === p2) { el.textContent = '✓ Les mots de passe correspondent'; el.className = 'pw-match ok'; }
  else { el.textContent = '✗ Les mots de passe ne correspondent pas'; el.className = 'pw-match err'; }
}

function showError(msg) {
  const el = document.getElementById('errorMsg');
  el.textContent = msg; el.classList.add('visible');
  setTimeout(() => el.classList.remove('visible'), 6000);
}

function setProgress(pct, label) {
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = label;
}

function toBase64(bytes) {
  let binary = '';
  const chunkSize = 8192;
  for (let i = 0; i < bytes.length; i += chunkSize) {
    binary += String.fromCharCode(...bytes.subarray(i, i + chunkSize));
  }
  return btoa(binary);
}

async function process() {
  const ppd = parseInt(document.getElementById('pagesPerDoc').value);
  const title = document.getElementById('docTitle').value.trim();
  if (!pdfBytes) { showError('Aucun fichier PDF chargé.'); return; }
  if (!ppd || ppd < 1) { showError('Veuillez indiquer un nombre de pages par document.'); return; }
  if (!title) { showError('Veuillez entrer un titre pour les documents.'); return; }
  if (pwSelected === null) { showError('Veuillez choisir si vous souhaitez protéger les fichiers ou non.'); return; }
  let password = '';
  if (pwSelected) {
    const p1 = document.getElementById('pw1').value, p2 = document.getElementById('pw2').value;
    if (!p1) { showError('Veuillez entrer un mot de passe.'); return; }
    if (p1 !== p2) { showError('Les mots de passe ne correspondent pas.'); return; }
    password = p1;
  }

  document.getElementById('btnProcess').disabled = true;
  document.getElementById('progressWrap').classList.add('visible');
  document.getElementById('downloadWrap').classList.remove('visible');
  setProgress(10, 'Envoi au serveur...');

  try {
    const pdfB64 = toBase64(pdfBytes);
    setProgress(30, 'Traitement en cours...');

    const resp = await fetch('/.netlify/functions/split_pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        pdf: pdfB64,
        pagesPerDoc: ppd,
        title: title,
        password: password,
        zipName: originalFileName
      })
    });

    setProgress(80, 'Réception du ZIP...');
    const data = await resp.json();

    if (!resp.ok || data.error) {
      showError(data.error || 'Erreur serveur inconnue.');
      document.getElementById('btnProcess').disabled = false;
      return;
    }

    // Decode ZIP and create download link
    const zipBinary = atob(data.zip);
    const zipBytes = new Uint8Array(zipBinary.length);
    for (let i = 0; i < zipBinary.length; i++) zipBytes[i] = zipBinary.charCodeAt(i);
    const blob = new Blob([zipBytes], { type: 'application/zip' });
    const url = URL.createObjectURL(blob);

    const link = document.getElementById('downloadLink');
    link.href = url;
    link.download = data.zipName;

    setProgress(100, 'Terminé !');

    const n = data.totalDocs;
    const msg = password
      ? `✅ ${n} document${n > 1 ? 's' : ''} créé${n > 1 ? 's' : ''}, protégé${n > 1 ? 's' : ''} par mot de passe AES-256.`
      : `✅ ${n} document${n > 1 ? 's' : ''} PDF créé${n > 1 ? 's' : ''} avec succès.`;
    document.getElementById('successMsg').textContent = msg;
    document.getElementById('downloadWrap').classList.add('visible');

  } catch (err) {
    showError('Erreur réseau : ' + err.message);
    console.error(err);
  }

  document.getElementById('btnProcess').disabled = false;
}

function reset() {
  pdfBytes = null; pageCount = 0; originalFileName = ''; pwSelected = null;
  document.getElementById('fileInput').value = '';
  document.getElementById('infoBadge').style.display = 'none';
  document.getElementById('paramsSection').style.display = 'none';
  document.getElementById('pagesPerDoc').value = '';
  document.getElementById('docTitle').value = '';
  document.getElementById('pw1').value = ''; document.getElementById('pw2').value = '';
  document.getElementById('pwMatch').textContent = '';
  document.getElementById('pwSection').classList.remove('visible');
  document.getElementById('radioYes').classList.remove('selected');
  document.getElementById('radioNo').classList.remove('selected');
  document.getElementById('previewPill').classList.remove('visible');
  document.getElementById('progressWrap').classList.remove('visible');
  document.getElementById('downloadWrap').classList.remove('visible');
  document.getElementById('progressFill').style.width = '0%';
}
</script>
</body>
</html>
